{
  "ConnectionStrings": {
    "ForgeDb": "Host=localhost;Port=5432;Database=forgekeeper;Username=forgekeeper;Password=forgekeeper"
  },
  "Storage": {
    "BasePaths": ["/mnt/3dprinting"],
    "ThumbnailDir": ".thumbnails"
  },
  "Scanner": {
    "FileTypes": ["stl", "obj", "3mf", "lys", "ctb", "cbddlp", "gcode", "sl1"],
    "ImageTypes": ["png", "jpg", "jpeg", "webp", "gif"],
    "IgnorePatterns": ["*.tmp", "*.DS_Store", "Thumbs.db"]
  },
  "Search": {
    "MinTrigramSimilarity": 0.3,
    "ResultsPerPage": 50
  },
  "Thumbnails": {
    "Enabled": true,
    "Size": "256x256",
    "Format": "webp",
    "Renderer": "stl-thumb"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
