{
  "ConnectionStrings": {
    "ForgeDb": "Host=localhost;Port=5432;Database=forgekeeper;Username=forgekeeper;Password=forgekeeper"
  },
  "Storage": {
    "BasePaths": ["/mnt/3dprinting"],
    "ThumbnailDir": ".forgekeeper/thumbnails"
  },
  "Scanner": {
    "FileTypes": ["stl", "obj", "3mf", "lys", "ctb", "cbddlp", "gcode", "sl1"],
    "ImageTypes": ["png", "jpg", "jpeg", "webp", "gif"],
    "IgnorePatterns": ["*.tmp", "*.DS_Store", "Thumbs.db"],
    "IntervalHours": 6,
    "ScanOnStartup": true
  },
  "Search": {
    "MinTrigramSimilarity": 0.3,
    "ResultsPerPage": 50
  },
  "Thumbnails": {
    "Enabled": true,
    "Size": "256x256",
    "Format": "webp",
    "Renderer": "stl-thumb"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Security": {
    "ApiKey": ""
  },
  "Plugins": {
    // PreferBundled: controls which plugin source wins when the same slug exists in both
    // /app/plugins (image-bundled) and /data/plugins (NFS-persistent / user-installed).
    //
    // false (default) = data-over-app: /data/plugins wins on conflict.
    //   Keep this for setups where operators hot-patch plugins on the PVC without rebuilding the image.
    //
    // true = app-over-data: /app/plugins wins on conflict (RECOMMENDED for Docker/k8s immutable-infra).
    //   To override a specific plugin, delete it from /data/plugins/<slug>/.
    //
    "PreferBundled": false,

    // WarnOnVersionDrift: when enabled, the host will ERROR and refuse to start if the SAME plugin
    // version is found in both /app/ and /data/ directories but the DLL bytes differ.
    // This catches the "stale /data/ after image rebuild" scenario early.
    // Resolve by deleting the /data/plugins/<slug>/ directory, then restart.
    //
    "WarnOnVersionDrift": false,

    // Other plugin toggles:
    "ForceLoadIncompatible": false,
    "HotReloadEnabled": false
  },
  "AllowedHosts": "*"
}
