# Forgekeeper Docker Compose Configuration
# Copy this to .env and update values

# Path to your 3D printing collection directory
# This should contain creator/model subdirectories
# Example: /home/user/3d-printing or /mnt/nas/stl-library
LIBRARY_PATH=/path/to/your/3d-printing-collection

# Encryption key for stored secrets (API keys, tokens)
# Generate with: openssl rand -hex 32
FORGEKEEPER_ENCRYPTION_KEY=change-me-to-something-random

# MyMiniFactory credentials (for the MMF scraper plugin)
# Configure these in the Forgekeeper UI: Plugins → MMF → Config
# Or set them here and they'll be picked up on first run
# MMF_USERNAME=your-email@example.com
# MMF_PASSWORD=your-mmf-password
